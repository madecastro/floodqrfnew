---
layout: page.njk
title: Blog
permalink: /blog/
tags: []
---

<div class="grid md:grid-cols-3 gap-6">
  {% for post in collections.blog | reverse %}
    <a href="{{ post.url }}" class="block border rounded-lg overflow-hidden bg-white shadow-sm hover:shadow">
      {% if post.data.image %}
        <img src="{{ post.data.image }}" alt="{{ post.data.title }}" class="w-full h-48 object-cover" />
      {% endif %}
      <div class="p-6">
        <div class="font-bold text-xl">{{ post.data.title }}</div>
        {% if post.data.date %}<p class="text-sm text-gray-500 mt-1">{{ helpers.formatDate(post.data.date) }}</p>{% endif %}
        {% if post.data.excerpt %}<p class="mt-2 text-gray-700">{{ post.data.excerpt }}</p>{% endif %}
        <div class="mt-4 underline text-blue-900 font-semibold">Read more</div>
      </div>
    </a>
  {% endfor %}
</div>
